RewriteEngine On

# www'yi kaldırarak HTTPS'ye yönlendir
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Statik dosyalar için istisna: CSS, JS, resim vb.
RewriteCond %{REQUEST_FILENAME} \.(gif|jpe?g|png|js|css|swf|ico|txt|pdf|xml)$ [NC,OR]
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]


# Özel sayfalar için yönlendirme
RewriteRule ^lastikler/([0-9a-zA-Z-_]+)$ index.php?p=lastikler&page=$1 [L,QSA]
RewriteRule ^jantlar/([0-9a-zA-Z-_]+)$ index.php?p=jantlar&page=$1 [L,QSA]
RewriteRule ^kampanyalar/([0-9a-zA-Z-_]+)$ index.php?p=kampanyalar&page=$1 [L,QSA]
RewriteRule ^kampanya/([0-9a-zA-Z-_]+)/([0-9a-zA-Z-_]+)$ index.php?p=kampanya&name=$1&id=$2 [L,QSA]
RewriteRule ^lastik/([0-9a-zA-Z-_]+)$ index.php?p=lastik&model_link=$1 [L,QSA]
RewriteRule ^jant/([0-9a-zA-Z-_]+)$ index.php?p=jant&model_link=$1 [L,QSA]


# Tüm diğer istekler için genel yönlendirme
RewriteRule ^(.*)$ index.php?p=$1 [QSA,L]
