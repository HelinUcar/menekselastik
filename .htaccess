RewriteEngine On

# www'yi kaldırarak HTTPS'ye yönlendir
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

# Statik dosyalar için istisna: CSS, JS, resim vb.
RewriteCond %{REQUEST_FILENAME} \.(gif|jpe?g|png|js|css|swf|ico|txt|pdf|xml)$ [NC,OR]
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]


RewriteRule ^duyuru-arama$ index.php?p=duyuru-arama [L]

# Tüm diğer istekler için genel yönlendirme
RewriteRule ^(.*)$ index.php?p=$1 [QSA,L]
